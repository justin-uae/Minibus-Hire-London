{
  "name": "taxi-booking",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "build": "vite build",
    "generate-blogs": "node generate-blogs.mjs",
    "build:full": "vite build && node generate-blogs.mjs",
    "postbuild": "react-snap",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "fallback": "200.html",
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "puppeteerExecutablePath": "",
    "crawl": true,
    "inlineCss": false,
    "skipThirdPartyRequests": true,
    "include": [
      "/",
      "/about",
      "/contact",
      "/vehicles",
      "/transport-options",
      "/car-rental-options",
      "/coachhire",
      "/minibus",
      "/blogs",
      "/terms",
      "/privacy"
    ],
    "exclude": [
      "/payment",
      "/car-rental/:carId",
      "/viewBlog/:slug"
    ]
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "leaflet": "^1.9.4",
    "leaflet-defaulticon-compatibility": "^0.1.2",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-google-recaptcha": "^3.1.0",
    "react-helmet-async": "^3.0.0",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-google-recaptcha": "^2.1.9",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}